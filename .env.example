# ========================================
# OMNIGO - Example Environment
# Copy this to .env and fill in your values
# ========================================

# App
APP_ENV=development
APP_PORT=3000

# ---- Supabase ----
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_JWT_SECRET=your_jwt_secret

# ---- PostgreSQL (Supabase) ----
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password
POSTGRES_HOST=db.xxxxx.supabase.co
POSTGRES_DATABASE=postgres
POSTGRES_URL=postgres://postgres.xxxxx:password@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres?sslmode=require
POSTGRES_URL_NON_POOLING=postgres://postgres.xxxxx:password@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres?sslmode=require

# ---- DB aliases (used by NestJS config + Python AI Service) ----
DB_HOST=db.xxxxx.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your_password
DATABASE_URL=postgres://postgres.xxxxx:password@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres?sslmode=require

# ---- Redis ----
REDIS_URL=redis://default:password@host:port
REDIS_HOST=your_redis_host
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_PREFIX=omnigo:

# ---- Cloudflare R2 ----
R2_ACCOUNT_ID=your_account_id
R2_ENDPOINT=https://your_account_id.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your_access_key
R2_SECRET_ACCESS_KEY=your_secret_key
R2_API_TOKEN=your_api_token
R2_BUCKET_PUBLIC=omnigo-media
R2_PUBLIC_URL=https://your-pub-url.r2.dev

# ---- CORS ----
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:5173

PAYOS_CLIENT_ID=your_web_client_id
PAYOS_API_KEY=your_web_api_key
PAYOS_CHECKSUM_KEY=your_web_checksum_key

PAYOS_APP_CLIENT_ID=your_app_client_id
PAYOS_APP_API_KEY=your_app_api_key
PAYOS_APP_CHECKSUM_KEY=your_app_checksum_key

# ---- AI Service ----
AI_SERVICE_URL=http://localhost:8000

# ---- Firebase ----
FIREBASE_PROJECT_ID=

# ---- Email (Resend) ----
RESEND_API_KEY=

# ---- GHN Shipping ----
GHN_API_TOKEN=
GHN_SHOP_ID=

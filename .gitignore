# ========================================
# OMNIGO .gitignore
# ========================================

# ---- Environment & Secrets ----
.env
.env.local
.env.*.local
*.pem
*.key

# ---- Flutter / Dart ----
**/build/
**/.dart_tool/
**/.flutter-plugins
**/.flutter-plugins-dependencies
**/.packages
**/.pub-cache/
**/.pub/
**/pubspec.lock
*.iml
*.ipr
*.iws
.idea/

# ---- Android ----
**/android/.gradle/
**/android/app/debug/
**/android/app/profile/
**/android/app/release/
**/android/captures/
**/android/gradlew
**/android/gradlew.bat
**/android/local.properties
**/android/**/GeneratedPluginRegistrant.java
**/android/key.properties
*.jks
*.keystore

# ---- iOS / macOS ----
**/ios/Pods/
**/ios/.symlinks/
**/ios/Flutter/Flutter.framework
**/ios/Flutter/Flutter.podspec
**/ios/Flutter/Generated.xcconfig
**/ios/Flutter/app.flx
**/ios/Flutter/engine/
**/ios/ServiceDefinitions.json
**/ios/Runner/GeneratedPluginRegistrant.*
**/macos/Pods/
**/macos/Flutter/GeneratedPluginRegistrant.swift
**/macos/Flutter/ephemeral/

# ---- Windows ----
**/windows/flutter/generated_plugin_registrant.cc
**/windows/flutter/generated_plugin_registrant.h
**/windows/flutter/generated_plugins.cmake

# ---- Linux ----
**/linux/flutter/generated_plugin_registrant.cc
**/linux/flutter/generated_plugin_registrant.h
**/linux/flutter/generated_plugins.cmake

# ---- Web ----
**/web/favicon.png
**/web/icons/

# ---- Node.js (NestJS) ----
**/node_modules/
**/dist/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn/cache
.yarn/unplugged
.yarn/install-state.gz

# ---- Python (FastAPI) ----
**/__pycache__/
**/*.py[cod]
**/venv/
**/.venv/
*.egg-info/
.eggs/

# ---- Docker ----
docker-compose.override.yml

# ---- IDE ----
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# ---- Coverage / Testing ----
coverage/
*.lcov
.coverage
htmlcov/

# ---- Misc ----
*.log
*.tmp
*.temp
.cache/

# ---- User Requested ----
**/.*/
*.md
.env
backend/core-api/.env
